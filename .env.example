# ════════════════════════════════════════════════════════════════════════════
# VIP Suite — Configuração de Ambiente para VPS
# Copie para .env e preencha: cp .env.example .env
# ════════════════════════════════════════════════════════════════════════════

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3098
VITE_APP_TITLE=VIP Suite
VITE_APP_PUBLIC_URL=https://bvsuite.example.com

# ─── Banco MySQL local (gerenciado pelo docker-compose) ──────────────────────
DB_ROOT_PASSWORD=troque_esta_senha_root
DB_NAME=bvsuite
DB_USER=bvsuite
DB_PASSWORD=troque_esta_senha
DATABASE_URL=mysql://bvsuite:troque_esta_senha@mysql:3306/bvsuite

# ─── Redis (gerenciado pelo docker-compose) ──────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Auth (Manus OAuth) ──────────────────────────────────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=https://login.manus.im
VITE_OAUTH_PORTAL_URL=https://login.manus.im
JWT_SECRET=gerar_com_openssl_rand_base64_32
OWNER_OPEN_ID=
OWNER_NAME=Barbearia VIP

# ─── APIs do Forge (storage, LLM, etc.) ──────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ─── Banco externo via túnel SSH (Data VIP — franquia_producao) ───────────────
# Deixe em branco se não for usar o Data VIP no VPS
SSH_TUNNEL_HOST=
SSH_TUNNEL_PORT=22
SSH_TUNNEL_USER=
SSH_TUNNEL_PASS=
DB_EXT_USER=
DB_EXT_PASS=
DB_EXT_NAME=franquia_producao

# ─── Google Business Profile (Reputação) ───────────────────────────────────
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/var/log/vip-suite

# ─── SSL / Domínio (usado pelo script de deploy para emitir certificado) ────
DOMAIN=bvsuite.example.com
SSL_EMAIL=admin@example.com